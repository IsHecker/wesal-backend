# Add a new migration
dotnet ef migrations add <MigrationName> --project src/Wesal.Infrastructure --startup-project src/Wesal.Api

# Apply migrations to the database
dotnet ef database update --project src/Wesal.Infrastructure --startup-project src/Wesal.Api

# Remove the last migration (before applying to DB)
dotnet ef migrations remove --project src/Wesal.Infrastructure --startup-project src/Wesal.Api


# Restore dependencies
dotnet restore

# Build the project
dotnet build


# Publish the API project to a 'publish' folder
dotnet publish src/Wesal.Api/Wesal.Api.csproj -c Release -o ./publish